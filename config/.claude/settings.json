{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git fetch:*)",
      "Bash(git ls-files:*)",
      "Bash(git blame:*)",
      "Bash(git reflog:*)",
      "Bash(git tag:*)",
      "Bash(git config --get:*)",
      "Bash(git config --list:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",
      "Bash(kubectl explain:*)",
      "Bash(kubectl top:*)",
      "Bash(kubectl config:*)",
      "Bash(helm list:*)",
      "Bash(helm get:*)",
      "Bash(helm status:*)",
      "Bash(helm history:*)",
      "Bash(helm show:*)",
      "Bash(helm search:*)",
      "Bash(helm version:*)",
      "Bash(aws ec2 describe-instances:*)",
      "Bash(aws ec2 describe-regions:*)",
      "Bash(aws ec2 describe-vpcs:*)",
      "Bash(aws ec2 describe-subnets:*)",
      "Bash(aws ec2 describe-security-groups:*)",
      "Bash(aws eks describe-cluster:*)",
      "Bash(aws eks list-clusters:*)",
      "Bash(aws s3 ls:*)",
      "Bash(aws iam get-user:*)",
      "Bash(aws iam get-role:*)",
      "Bash(aws iam list-users:*)",
      "Bash(aws iam list-roles:*)",
      "Bash(aws rds describe-db-instances:*)",
      "Bash(aws cloudformation describe-stacks:*)",
      "Bash(aws cloudformation list-stacks:*)",
      "Bash(aws sts get-caller-identity:*)",
      "Bash(awsenv:*)",
      "Bash(~/.claude/scripts/fetch-my-jira-tickets.sh)",
      "Bash(~/.claude/scripts/task-manager.sh:*)",
      "Bash(.claude/scripts/ch-debug.sh:*)",
      "Bash(.claude/scripts/ch-debug.sh *:*)",
      "Bash(.claude/scripts/k8s-ops.sh:*)",
      "Bash(.claude/scripts/k8s-ops.sh *:*)"
    ],
    "defaultMode": "default"
  },
  "model": "haiku",
  "statusLine": {
    "type": "command",
    "command": "oh-my-posh claude --config ~/.config/oh-my-posh/claude.toml",
    "padding": 0
  },
  "enabledPlugins": {
    "engexp@engexp-marketplace": false,
    "engexp-runbooks@engexp-runbooks": false,
    "lua-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "editorMode": "vim"
}
